{
  // Workspaces
  "niri/workspaces": {
    "on-click": "activate"
  },

  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 21,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["Alacritty", "kitty", "ghostty"],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "LibreWolf Web Browser": "LibreWolf",
      "Foot Server": "Terminal"
    }
  },

  // niri Window
  "niri/window": {
    "format": "{}",
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  // Empty
  "custom/empty": {
    "format": ""
  },

  // Tools
  "custom/tools": {
    "format": "´ù¢",
    "tooltip-format": "Tools"
  },

  // Updates Count
  "custom/updates": {
    "format": "{} {icon}",
    "return-type": "json",
    "format-icons": {
      "has-updates": "¾▒ìÀ",
      "updated": "¾░é¬"
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300",
    "on-click": "octopi"
  },

  // wofi Application Launcher
  "custom/appmenu": {
    "format": "   ",
    "on-click": "sleep 0.2;wofi",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // wofi Application Launcher
  "custom/appmenuicon": {
    "format": "´îâ",
    "on-click": "sleep 0.2;wofi -show drun -replace",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // Power Menu
  "custom/exit": {
    "format": " ! ",
    "on-click": "/home/alex/.config/waybar/scripts/power-menu.sh",
    "tooltip-format": "Power Menu"
  },

  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "´Çú",
      "unlocked": "´é£"
    }
  },

  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  // Clock
  "clock": {
    "format": "{:%H:%M %a %D}",
    "on-click": "dde-calendar",
    "tooltip": false
  },

  "niri/language": {
    "format": "/ K {short}"
  },

  // Battery
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-charging": "{icon}´âº",
    "format-plugged": "´çª",
    "tooltip-format": "Entl├ñdt ({capacity}%)",
    "tooltip-format-charging": "L├ñdt ({capacity}%)",
    "tooltip-format-full": "{capacity}% Voll",
    // "format-good": "", // An empty format will hide the module
    "format-full": "´ëÇ ",
    "format-icons": ["´ëä ", "´ëâ ", "´ëé ", "´ëü ", "´ëÇ "],
    "on-click": "/home/alex/.config/waybar/scripts/power-settings.sh"
  },

  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{volume}%",
    "format-bluetooth": "{volume}% {icon}´èö {format_source}",
    "format-bluetooth-muted": "´Ü® {icon}´èö {format_source}",
    "format-muted": "´Ü® {format_source}",
    "format-source": "{volume}% ´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {},
    "on-click": "pavucontrol-qt"
  },

  // Bluetooth
  "bluetooth": {
    "format": "´èô {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  "network": {
    "interface": "wlan0",
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-icons": ["¾░ñ» ", "¾░ñƒ ", "¾░ñó ", "¾░ñÑ ", "¾░ñ¿ "],
    "format-ethernet": "{ipaddr}/{cidr} ¾░èù ",
    "format-disconnected": "", //An empty format will hide the module.
    "tooltip-format": "{ifname} via {gwaddr} ¾░èù ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname} ´âü ",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "alacritty -e sudo wifi-menu"
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "¯Äì",
      "¯Åö",
      "¯Åô",
      "¯ÅÆ",
      "¯Åæ",
      "¯ÅÉ",
      "¯ÅÅ",
      "¯ÅÄ",
      "¯Åì",
      "¯Åî",
      "¯Åï",
      "¯Åè",
      "¯Åë",
      "¯Åê",
      "¯Äø"
    ],
    "scroll-step": 1
  }
}
